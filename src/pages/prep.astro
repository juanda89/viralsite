---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';

// Post-booking intake. The HighLevel calendar should redirect here after a booking.
// On submit we POST the answers to the n8n webhook "VI-CAPI Lead", which upserts the SAME
// GHL contact (matched by email) with these custom fields + fires the Lead CAPI event. See PREP-SETUP.md.
const PREP_WEBHOOK = 'https://n8n-execute-viralbbm-u44048.vm.elestio.app/webhook/vi-capi-lead';

// Questions grouped into themed blocks so the form reads short, not like a wall.
// `wide: true` → long labels render as full-width rows; otherwise as a compact chip grid.
const groups = [
  {
    title: 'Your videos today',
    sub: 'So we size the right team, cadence and workflow.',
    icon: 'ph:video-fill',
    items: [
      { key: 'bottleneck', q: "What's slowing your video output down most?", wide: true,
        options: [
          { v: 'freelancers', label: 'Freelancers ghosting or inconsistent quality' },
          { v: 'agency', label: 'Agency too slow or expensive' },
          { v: 'inhouse', label: 'In-house team at capacity' },
          { v: 'nosystem', label: 'No system — everything ad hoc' },
          { v: 'other', label: 'Something else' },
        ] },
      { key: 'volume', q: 'How many videos a month do you need?',
        options: [{ v: 'v0', label: '1–10' }, { v: 'v1', label: '10–30' }, { v: 'v2', label: '30–100' }, { v: 'v3', label: '100+' }] },
      { key: 'content', q: 'What content matters most right now?', wide: true,
        options: [
          { v: 'short', label: 'Short-form (Reels, TikTok, Shorts)' },
          { v: 'long', label: 'Long-form & YouTube' },
          { v: 'ads', label: 'Paid ads' },
          { v: 'mix', label: 'A mix of everything' },
        ] },
      { key: 'readiness', q: 'Got footage and a content cadence ready?',
        options: [{ v: 'yes', label: 'Yes, regularly' }, { v: 'sometimes', label: 'Sometimes' }, { v: 'no', label: 'Not yet' }] },
    ],
  },
  {
    title: 'You & the engagement',
    sub: 'So we tailor the plan and who joins the call.',
    icon: 'ph:user-circle-fill',
    items: [
      { key: 'role', q: "What's your role?",
        options: [{ v: 'founder', label: 'Founder / CEO' }, { v: 'marketing', label: 'Head of Marketing / CMO' }, { v: 'agency', label: 'Agency owner' }, { v: 'other', label: 'Other' }] },
      { key: 'budget', q: "What's your monthly budget for video?",
        options: [{ v: 'b0', label: 'Under $1k' }, { v: 'b1', label: '$1k–$2.5k' }, { v: 'b2', label: '$2.5k–$5k' }, { v: 'b3', label: '$5k+' }] },
      { key: 'timeline', q: 'When do you want to start?',
        options: [{ v: 'asap', label: 'ASAP' }, { v: 'month', label: 'This month' }, { v: 'quarter', label: 'This quarter' }, { v: 'explore', label: 'Just exploring' }] },
    ],
  },
];
const flat = groups.flatMap((g) => g.items);
const total = flat.length;
// running 1-based number per question across groups
let n = 0;
const numbered = groups.map((g) => ({ ...g, items: g.items.map((it) => ({ ...it, num: ++n })) }));
---
<Base title="Before your call — Viral Ideas">
  <header class="mx-auto flex h-16 max-w-3xl items-center px-5 sm:px-8">
    <a href="/" aria-label="Viral Ideas home"><img src="/media/vi-logo.png" alt="Viral Ideas" class="vi-logo h-6 w-auto" /></a>
  </header>

  <!-- sticky progress: constant momentum feedback while answering -->
  <div data-progress-wrap hidden class="sticky top-0 z-30 border-b border-line/70 bg-canvas/85 backdrop-blur-md">
    <div class="mx-auto flex max-w-3xl items-center gap-3 px-5 py-2.5 sm:px-8">
      <div class="h-1.5 flex-1 overflow-hidden rounded-full bg-surface2">
        <div data-progress-bar class="h-full w-0 rounded-full bg-gradient-to-r from-violet to-violet-bright transition-[width] duration-500 ease-out"></div>
      </div>
      <span class="shrink-0 text-[13px] font-semibold tabular-nums text-muted"><span data-answered>0</span><span class="text-faint">/{total}</span></span>
    </div>
  </div>

  <main class="mx-auto max-w-3xl px-5 pb-28 pt-6 sm:px-8">
    <div data-reveal class="in text-center">
      <span class="inline-flex items-center gap-2 rounded-full border border-violet/40 bg-violet/12 px-3 py-1 text-[13px] font-medium text-violet-bright">
        <Icon name="ph:check-circle-fill" class="h-4 w-4" /> Your call is booked
      </span>
      <h1 class="mt-5 font-display text-3xl font-bold leading-[1.1] tracking-tight sm:text-[2.6rem]">
        One last step, so your call is <span class="text-violet-bright">actually worth it</span>
      </h1>
      <p class="mx-auto mt-4 max-w-xl text-lg leading-relaxed text-muted">
        Just tap your answers. We'll walk in already knowing your setup — and use the whole call on <span class="text-ink">your plan</span>, not discovery.
      </p>
      <!-- value, made obvious -->
      <ul class="mx-auto mt-6 flex max-w-xl flex-wrap items-center justify-center gap-x-5 gap-y-2 text-[13.5px] text-muted">
        <li class="inline-flex items-center gap-1.5"><Icon name="ph:target" class="h-4 w-4 text-violet-bright" /> A plan built around your bottleneck</li>
        <li class="inline-flex items-center gap-1.5"><Icon name="ph:lightning-fill" class="h-4 w-4 text-violet-bright" /> Zero wasted discovery</li>
        <li class="inline-flex items-center gap-1.5"><Icon name="ph:cursor-click-fill" class="h-4 w-4 text-violet-bright" /> ~40 seconds, just taps</li>
      </ul>
    </div>

    <form data-prep class="mt-9 space-y-5" novalidate>
      <!-- identity: collapses to a confirmation chip when prefilled from the booking redirect -->
      <div data-identity-summary hidden class="flex flex-wrap items-center justify-between gap-3 rounded-2xl border border-line bg-surface px-5 py-3.5">
        <span class="inline-flex items-center gap-2.5 text-[15px]">
          <Icon name="ph:user-circle-fill" class="h-5 w-5 text-violet-bright" />
          <span>Booking as <b data-id-name class="font-semibold text-ink"></b> <span class="text-faint">·</span> <span data-id-email class="text-muted"></span></span>
        </span>
        <button type="button" data-id-edit class="text-[13.5px] font-medium text-violet-bright transition hover:text-ink">Edit</button>
      </div>
      <div data-identity-fields class="grid gap-4 rounded-2xl border border-line bg-surface p-5 sm:grid-cols-2 sm:p-6">
        <label class="block">
          <span class="mb-1.5 block text-sm font-medium text-muted">Your name</span>
          <input name="name" type="text" autocomplete="name"
            class="w-full rounded-xl border border-line bg-canvas/60 px-4 py-3 text-ink outline-none transition placeholder:text-faint focus:border-violet/60 focus:ring-2 focus:ring-violet/20" placeholder="Jane Rivera" />
        </label>
        <label class="block">
          <span class="mb-1.5 block text-sm font-medium text-muted">Email (the one you booked with)</span>
          <input name="email" type="email" required autocomplete="email"
            class="w-full rounded-xl border border-line bg-canvas/60 px-4 py-3 text-ink outline-none transition placeholder:text-faint focus:border-violet/60 focus:ring-2 focus:ring-violet/20" placeholder="jane@company.com" />
        </label>
      </div>

      {numbered.map((group) => (
        <section class="rounded-[var(--radius-card)] border border-line bg-surface p-5 sm:p-7">
          <div class="mb-5 flex items-center gap-3">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-xl bg-violet/15 text-violet-bright ring-1 ring-violet/25">
              <Icon name={group.icon} class="h-5 w-5" />
            </span>
            <div>
              <h2 class="font-display text-base font-bold tracking-tight text-ink">{group.title}</h2>
              <p class="text-[13px] text-faint">{group.sub}</p>
            </div>
          </div>

          <div class="space-y-6">
            {group.items.map((item) => (
              <fieldset data-q data-key={item.key}>
                <legend class="flex items-baseline gap-2 text-[15px] font-semibold tracking-tight text-ink">
                  <span class="text-[13px] font-bold tabular-nums text-violet-bright">{String(item.num).padStart(2, '0')}</span>
                  {item.q}
                </legend>
                <div class={item.wide ? 'mt-3 grid gap-2.5' : 'mt-3 grid grid-cols-2 gap-2.5 sm:grid-cols-4'}>
                  {item.options.map((o) => (
                    <button type="button" data-opt data-value={o.v} aria-pressed="false"
                      class={(item.wide
                        ? 'group flex w-full items-center justify-between gap-3 text-left aria-pressed:bg-violet/18 aria-pressed:text-ink '
                        : 'group flex items-center justify-center gap-2 text-center aria-pressed:bg-violet/100 aria-pressed:text-white ') +
                        'rounded-xl border border-line bg-surface2 px-4 py-3.5 text-[15px] font-medium text-ink transition ' +
                        'hover:border-violet/60 hover:bg-violet/10 aria-pressed:border-violet ' +
                        'aria-pressed:shadow-[0_8px_26px_-12px_rgba(105,108,252,0.7)] ' +
                        'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-violet/50'}>
                      <span>{o.label}</span>
                      <span class={(item.wide ? 'h-5 w-5 shrink-0 ' : 'absolute hidden ') +
                        'grid place-items-center rounded-full border border-line text-transparent transition ' +
                        'group-aria-pressed:border-violet group-aria-pressed:bg-violet group-aria-pressed:text-white'} aria-hidden="true">
                        <Icon name="ph:check-bold" class="h-3 w-3" />
                      </span>
                    </button>
                  ))}
                </div>
              </fieldset>
            ))}
          </div>
        </section>
      ))}

      <div class="flex flex-col items-center gap-3 pt-2 text-center">
        <button type="submit" data-submit disabled
          class="group inline-flex w-full items-center justify-center gap-2.5 rounded-full bg-gradient-to-b from-violet to-violet-deep
                 px-7 py-4 text-[17px] font-semibold text-white shadow-[0_16px_44px_-12px_rgba(105,108,252,0.75)]
                 transition active:translate-y-px disabled:cursor-not-allowed disabled:from-surface2 disabled:to-surface2 disabled:text-faint disabled:shadow-none sm:w-auto">
          <span data-submit-label>Answer to lock in your plan</span>
          <Icon name="ph:arrow-right-bold" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
        </button>
        <p class="text-[13px] text-faint"><Icon name="ph:lock-simple-fill" class="-mt-0.5 mr-1 inline h-3.5 w-3.5" />We read every answer before your call. No generic pitch.</p>
      </div>
    </form>

    <div data-prep-done hidden class="mt-10 rounded-[var(--radius-card)] border border-violet/40 bg-surface p-8 text-center sm:p-10">
      <span class="mx-auto grid h-14 w-14 place-items-center rounded-full bg-violet/15 ring-1 ring-violet/30">
        <Icon name="ph:check-bold" class="h-7 w-7 text-violet-bright" />
      </span>
      <h2 class="mt-5 font-display text-2xl font-bold tracking-tight">You're all set</h2>
      <p class="mx-auto mt-3 max-w-md leading-relaxed text-muted">Thanks. We'll review your answers and come ready with a plan for your call. See you soon.</p>
      <a href="/" class="mt-7 inline-flex items-center gap-2 text-[15px] font-medium text-violet-bright transition hover:text-ink">
        Back to home <Icon name="ph:arrow-right-bold" class="h-4 w-4" />
      </a>
    </div>
  </main>
</Base>

<script define:vars={{ PREP_WEBHOOK }}>
  const form = document.querySelector('[data-prep]');
  if (form) {
    const params = new URLSearchParams(location.search);
    const nameI = form.querySelector('[name="name"]');
    const emailI = form.querySelector('[name="email"]');
    // prefill from the redirect (GHL can append ?name=&email=); ignore unfilled {{merge}} tokens
    const qp = (k) => { const v = params.get(k); return (v && !v.includes('{{')) ? v : ''; };
    if (qp('name')) nameI.value = qp('name');
    if (qp('email')) emailI.value = qp('email');

    // Identity: if both prefilled, collapse the inputs into a compact confirmation chip
    // so the user only taps options. "Edit" reveals the fields again.
    const idSummary = form.querySelector('[data-identity-summary]');
    const idFields = form.querySelector('[data-identity-fields]');
    const idName = form.querySelector('[data-id-name]');
    const idEmail = form.querySelector('[data-id-email]');
    const idEdit = form.querySelector('[data-id-edit]');
    function syncIdentityChip() {
      idName.textContent = nameI.value.trim() || 'you';
      idEmail.textContent = emailI.value.trim();
    }
    if (nameI.value.trim() && emailI.value.trim()) {
      syncIdentityChip();
      idFields.hidden = true;
      idSummary.hidden = false;
    }
    idEdit && idEdit.addEventListener('click', () => {
      idSummary.hidden = true;
      idFields.hidden = false;
      nameI.focus();
    });

    const fields = Array.from(form.querySelectorAll('[data-q]'));
    const submit = form.querySelector('[data-submit]');
    const submitLabel = form.querySelector('[data-submit-label]');
    const counter = document.querySelector('[data-answered]');
    const progressWrap = document.querySelector('[data-progress-wrap]');
    const progressBar = document.querySelector('[data-progress-bar]');
    const done = document.querySelector('[data-prep-done]');
    const answers = {};

    if (progressWrap) progressWrap.hidden = false;

    const qualified = () =>
      ['v1', 'v2', 'v3'].includes(answers.volume) &&
      ['b2', 'b3'].includes(answers.budget) &&
      answers.timeline !== 'explore';

    function refresh() {
      const done_n = Object.keys(answers).length;
      if (counter) counter.textContent = String(done_n);
      if (progressBar) progressBar.style.width = (done_n / fields.length * 100) + '%';
      const complete = done_n >= fields.length && !!emailI.value.trim();
      submit.disabled = !complete;
      if (submitLabel) submitLabel.textContent = complete ? 'Send and lock it in' : 'Answer to lock in your plan';
    }
    emailI.addEventListener('input', refresh);

    // gentle auto-advance: after a tap, scroll the NEXT question (or submit) into view
    function advanceFrom(fs) {
      const i = fields.indexOf(fs);
      const next = fields.slice(i + 1).find((f) => !answers[f.dataset.key]);
      const target = next || (Object.keys(answers).length >= fields.length ? submit : null);
      if (target) setTimeout(() => target.scrollIntoView({ behavior: 'smooth', block: 'center' }), 180);
    }

    fields.forEach((fs) => {
      const key = fs.dataset.key;
      fs.querySelectorAll('[data-opt]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const firstTime = !answers[key];
          fs.querySelectorAll('[data-opt]').forEach((b) => b.setAttribute('aria-pressed', 'false'));
          btn.setAttribute('aria-pressed', 'true');
          answers[key] = btn.dataset.value;
          refresh();
          if (firstTime) advanceFrom(fs);
        });
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (submit.disabled) return;
      // Meta attribution for CAPI matching: read first-touch from localStorage
      // (set on the landing by tracking.js), and let the GHL redirect override/add via query string.
      let attr = {};
      try { attr = JSON.parse(localStorage.getItem('vi_attr') || '{}'); } catch (err) {}
      ['fbclid', '_fbc', '_fbp', 'utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid'].forEach((k) => {
        const v = qp(k);
        if (v) attr[k] = v;
      });
      // Prefer the REAL first-party cookies the Meta Pixel set (best match quality);
      // by submit time fbevents.js has loaded. Fall back to the stored/synth value.
      const cookie = (n) => { const m = document.cookie.match('(^|;)\\s*' + n + '\\s*=\\s*([^;]+)'); return m ? m.pop() : ''; };
      const realFbc = cookie('_fbc');
      const realFbp = cookie('_fbp');

      const payload = {
        name: nameI.value.trim(),
        email: emailI.value.trim(),
        contact_id: qp('contact_id'),
        qualified: qualified(),
        ...answers,
        // attribution → GHL custom fields → consumed by the offline "Qualified" CAPI event
        fbclid: attr.fbclid || '',
        fbc: realFbc || attr._fbc || attr.fbc || '',
        fbp: realFbp || attr._fbp || attr.fbp || '',
        utm_source: attr.utm_source || '',
        utm_medium: attr.utm_medium || '',
        utm_campaign: attr.utm_campaign || '',
        utm_content: attr.utm_content || '',
        utm_term: attr.utm_term || '',
        gclid: attr.gclid || '',
        source: 'prep-form',
      };
      try { localStorage.setItem('vi_quiz', JSON.stringify(payload)); } catch (err) {}
      if (PREP_WEBHOOK) {
        try {
          await fetch(PREP_WEBHOOK, { method: 'POST', mode: 'no-cors',
            headers: { 'Content-Type': 'text/plain' }, body: JSON.stringify(payload) });
        } catch (err) { /* no-cors: opaque, ignore */ }
      }
      form.hidden = true;
      if (progressWrap) progressWrap.hidden = true;
      done.hidden = false;
      done.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }
</script>
