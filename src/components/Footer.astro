---
import { Icon } from 'astro-icon/components';
---
<footer class="border-t border-line/60 bg-surface/30">
  <div class="mx-auto max-w-[1240px] px-5 py-14 sm:px-8">
    <div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:justify-between">
      <div class="max-w-sm">
        <img src="/media/vi-logo.png" alt="Viral Ideas" class="vi-logo h-7 w-auto" />
        <p class="mt-4 leading-relaxed text-muted">
          Consistent video, delivered fast, so your team can focus on growth, not production.
        </p>
        <a href="#book" data-book
           class="mt-6 inline-flex items-center gap-2 rounded-full bg-gradient-to-b from-violet to-violet-deep
                  px-5 py-2.5 text-[15px] font-semibold text-white transition active:translate-y-px">
          Book your free call
          <Icon name="ph:arrow-right-bold" class="h-4 w-4" />
        </a>
      </div>

      <div class="flex flex-col gap-3 text-muted">
        <span class="text-[13px] font-medium uppercase tracking-[0.18em] text-faint">Contact</span>
        <span class="flex items-center gap-2.5"><Icon name="ph:map-pin" class="h-4 w-4 text-violet-bright" /> Philadelphia, PA</span>
        <a href="mailto:info@viralideamarketing.com" class="flex items-center gap-2.5 transition hover:text-ink">
          <Icon name="ph:envelope-simple" class="h-4 w-4 text-violet-bright" /> info@viralideamarketing.com
        </a>
        <a href="tel:+12677781908" class="flex items-center gap-2.5 transition hover:text-ink">
          <Icon name="ph:phone" class="h-4 w-4 text-violet-bright" /> 267-778-1908
        </a>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-3 border-t border-line/60 pt-6 text-sm text-faint sm:flex-row sm:items-center sm:justify-between">
      <span>© 2026 Viral Ideas. Creativity, simplified.</span>
      <span class="flex gap-5">
        <a href="#" class="transition hover:text-muted">Privacy Policy</a>
        <a href="#book" data-book class="transition hover:text-muted">Contact</a>
      </span>
    </div>
  </div>
</footer>
