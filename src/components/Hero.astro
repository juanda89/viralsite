---
import { Icon } from 'astro-icon/components';
---
<section class="relative isolate overflow-hidden">
  <!-- Atmosphere: layered violet glow + grid, gives depth (not a flat dark bg) -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute left-1/2 top-[-12%] h-[620px] w-[1100px] -translate-x-1/2 rounded-full
                bg-[radial-gradient(ellipse_at_center,var(--glow-strong),transparent_62%)] blur-2xl"></div>
    <div class="absolute right-[-6%] bottom-[6%] h-[420px] w-[520px] rounded-full
                bg-[radial-gradient(circle,var(--glow-soft),transparent_60%)] blur-2xl"></div>
    <div class="absolute inset-0 bg-grid"></div>
  </div>

  <div class="mx-auto grid max-w-[1240px] items-center gap-12 px-5 pb-16 pt-28 sm:px-8
              md:pt-36 lg:grid-cols-[1.04fr_0.96fr] lg:gap-10 lg:pb-24">
    <!-- Left: message -->
    <div class="max-w-2xl">
      <p class="vi-load font-medium text-violet-bright" style="animation-delay:.05s">
        <span class="inline-flex items-center gap-2 rounded-full border border-line bg-surface/60 px-3 py-1 text-[13px]">
          <span class="h-1.5 w-1.5 rounded-full bg-violet-bright"></span>
          For founders &amp; marketing teams
        </span>
      </p>

      <h1 class="vi-load mt-6 font-display text-[2.3rem] font-bold leading-[1.06] tracking-tight
                 sm:text-5xl lg:text-[3.25rem]" style="animation-delay:.12s">
        Scale your content with a <span class="text-violet-bright">system</span>,
        <span class="block">not more missed deadlines</span>
      </h1>

      <p class="vi-load mt-6 max-w-xl text-lg leading-relaxed text-muted" style="animation-delay:.2s">
        A dedicated video team trained on your brand from day one. You greenlight the work;
        production stops being your bottleneck.
      </p>

      <div class="vi-load mt-9" style="animation-delay:.28s">
        <a
          href="#book"
          data-book
          class="group inline-flex items-center gap-2.5 rounded-full bg-gradient-to-b from-violet to-violet-deep
                 px-7 py-3.5 text-[17px] font-semibold text-white
                 shadow-[0_14px_40px_-12px_rgba(105,108,252,0.7)] transition active:translate-y-px"
        >
          Book your free call
          <Icon name="ph:arrow-right-bold" class="h-4.5 w-4.5 transition-transform group-hover:translate-x-1" />
        </a>
      </div>

      <p class="vi-load mt-8 text-sm leading-relaxed text-faint" style="animation-delay:.36s">
        100,000+ videos edited since 2015, for solo founders and brands you know alike.
      </p>
    </div>

    <!-- Right: VSL (poster loads instantly; the video file loads only on click) -->
    <div class="vi-load relative" style="animation-delay:.22s" id="vsl">
      <div class="absolute -inset-3 -z-10 rounded-[28px] bg-violet/25 blur-2xl"></div>
      <div data-vsl data-src="/media/vsl.mp4"
           class="group relative aspect-video cursor-pointer overflow-hidden rounded-[var(--radius-card)] border border-line
                  bg-surface shadow-[var(--shadow-media)]">
        <img src="/media/vsl-poster.jpg" alt="How Viral Ideas works, with founder Dave"
             class="h-full w-full object-cover transition duration-700 group-hover:scale-[1.03]" loading="eager" />
        <!-- contrast layers (YT: text must pop at small size) -->
        <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-canvas/75 via-transparent to-canvas/15"></div>
        <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_36%_48%,transparent_36%,rgba(11,10,18,0.45))]"></div>
        <!-- YT-style bold hook (minimal, high-contrast, curiosity) -->
        <div class="pointer-events-none absolute right-4 top-4 max-w-[50%] text-right sm:right-5 sm:top-5">
          <p class="font-display text-[1.55rem] font-extrabold uppercase leading-[0.9] tracking-tight text-white
                    drop-shadow-[0_3px_14px_rgba(0,0,0,0.95)] sm:text-[2rem]">
            How we<br /><span class="text-violet-bright">actually</span><br />work
          </p>
        </div>
        <!-- focal point: glowing play -->
        <span class="pointer-events-none absolute left-1/2 top-1/2 grid h-[84px] w-[84px] -translate-x-1/2 -translate-y-1/2
                     place-items-center rounded-full bg-white text-canvas
                     shadow-[0_0_0_8px_rgba(255,255,255,0.12),0_14px_60px_rgba(105,108,252,0.85)]
                     transition group-hover:scale-110">
          <Icon name="ph:play-fill" class="ml-1 h-9 w-9" />
        </span>
        <!-- watch CTA + duration -->
        <div class="pointer-events-none absolute inset-x-4 bottom-4 flex items-center justify-between">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-violet px-3.5 py-1.5 text-[12px] font-bold uppercase
                       tracking-wide text-white shadow-[0_6px_20px_rgba(105,108,252,0.5)]">
            <Icon name="ph:play-fill" class="h-3 w-3" /> Watch the walkthrough
          </span>
          <span class="rounded-full bg-canvas/75 px-2.5 py-1 text-[12px] font-semibold text-ink backdrop-blur">1:54</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-vsl]').forEach((el) => {
    el.addEventListener('click', () => {
      const src = el.getAttribute('data-src');
      el.innerHTML = '';
      const v = document.createElement('video');
      v.src = src; v.controls = true; v.autoplay = true; v.playsInline = true;
      v.className = 'h-full w-full bg-black';
      el.appendChild(v);
    }, { once: true });
  });
</script>
