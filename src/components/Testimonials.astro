---
import { Icon } from 'astro-icon/components';
// Real testimonials (from viralideamarketing.com / Figma). TODO: add real photos.
const testimonials = [
  { name: 'Jacob Rogelberg', org: 'Viral Ideas client',
    quote: 'Their attention to detail, delivery, and product quality is unmatched. Looking forward to working with Viral again.' },
  { name: 'Abigail Greystoke', org: 'Viral Ideas client',
    quote: 'The professionalism, warmth and quality of the team is exceptional. In a crowded market, they consistently over-deliver.' },
  { name: 'Morgan Harrison', org: 'Viral Ideas client',
    quote: 'We value excellent communication above all. The team was responsive, open to feedback, and every project shipped on time.' },
  { name: 'Ashley Shepherd', org: 'Content Agency',
    quote: 'Modern short-form edits, quick turnaround, and they even help strategize how to record and promote our brand.' },
  { name: 'Michael Tangreti', org: 'Viral Ideas client',
    quote: 'Great team to work with. Well-prepared, with a great attitude toward their projects and their customers.' },
  { name: 'Zach Schleien', org: 'Founder',
    quote: 'I am always blown away by Viral’s editing skills. A great spot to fulfill your video needs.' },
];
function initials(n) { return n.split(' ').map((w) => w[0]).slice(0, 2).join(''); }
---
<section id="testimonials" class="border-y border-line/60 bg-surface/30">
  <div class="mx-auto max-w-[1240px] px-5 py-20 sm:px-8 lg:py-28">
    <div data-reveal class="max-w-2xl">
      <h2 class="font-display text-3xl font-bold leading-tight tracking-tight sm:text-4xl lg:text-[2.9rem]">
        From marketing teams <span class="text-violet-bright">that fixed it</span>
      </h2>
      <p class="mt-4 text-lg text-muted">Real names. Real fixes.</p>
    </div>

    <div class="mt-12 gap-5 [column-fill:balance] sm:columns-2 lg:columns-3">
      {testimonials.map((t, i) => (
        <figure data-reveal data-reveal-delay={i % 3}
                class="mb-5 break-inside-avoid rounded-[var(--radius-card)] border border-line bg-canvas/60 p-6">
          <Icon name="ph:star-fill" class="inline-block h-4 w-4 text-violet-bright" />
          <Icon name="ph:star-fill" class="inline-block h-4 w-4 text-violet-bright" />
          <Icon name="ph:star-fill" class="inline-block h-4 w-4 text-violet-bright" />
          <Icon name="ph:star-fill" class="inline-block h-4 w-4 text-violet-bright" />
          <Icon name="ph:star-fill" class="inline-block h-4 w-4 text-violet-bright" />
          <blockquote class="mt-4 leading-relaxed text-ink/90">{t.quote}</blockquote>
          <figcaption class="mt-5 flex items-center gap-3">
            <span class="grid h-10 w-10 place-items-center rounded-full bg-violet/15 font-display text-sm font-bold text-violet-bright ring-1 ring-violet/25">
              {initials(t.name)}
            </span>
            <span>
              <span class="block font-display text-sm font-semibold tracking-tight text-ink">{t.name}</span>
              <span class="block text-sm text-faint">{t.org}</span>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
