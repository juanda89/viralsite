---
import { Icon } from 'astro-icon/components';
---
<header class="fixed inset-x-0 top-0 z-50">
  <nav class="mx-auto flex h-16 max-w-[1240px] items-center justify-between px-5 sm:px-8
              border-b border-line/60 bg-canvas/70 backdrop-blur-xl">
    <a href="/" class="flex items-center" aria-label="Viral Ideas home">
      <img src="/media/vi-logo.png" alt="Viral Ideas" class="vi-logo h-6 w-auto sm:h-[26px]" />
    </a>

    <div class="flex items-center gap-4 sm:gap-6">
      <a href="#pricing" class="text-[15px] font-medium text-muted transition hover:text-ink">Pricing</a>
      <a href="#book" data-book
        class="group inline-flex items-center gap-2 rounded-full bg-gradient-to-b from-violet to-violet-deep
               px-4 py-2 text-[15px] font-semibold text-white shadow-[0_8px_24px_-8px_rgba(105,108,252,0.6)]
               transition active:translate-y-px sm:px-5">
        Book your free call
        <Icon name="ph:arrow-right-bold" class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
      </a>
    </div>
  </nav>
</header>
